@model recycling.Model.SortingCenterWorkers
@{
    ViewBag.Title = "个人中心";
    Layout = "~/Views/Shared/_SortingCenterWorkerLayout.cshtml";
}

<style>
    .profile-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 30px;
    }

    .profile-header {
        background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        color: white;
        padding: 30px;
        border-radius: 15px;
        margin-bottom: 30px;
        text-align: center;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        margin-bottom: 15px;
        cursor: pointer;
    }

    .welcome-text {
        font-size: 24px;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .member-info {
        opacity: 0.9;
        font-size: 14px;
    }

    .user-info-section {
        background: white;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.1);
        margin-bottom: 20px;
    }

    .info-title {
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 20px;
        color: #333;
        border-bottom: 2px solid #f0f0f0;
        padding-bottom: 10px;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f8f9fa;
    }

    .info-label {
        font-weight: bold;
        color: #333;
    }

    .info-value {
        color: #666;
    }

    .info-item:last-child {
        border-bottom: none;
    }

    .success-alert {
        background: #d4edda;
        border: 1px solid #c3e6cb;
        color: #155724;
        padding: 15px;
        border-radius: 5px;
        margin-bottom: 20px;
    }

    .btn-action {
        background: #e74c3c;
        color: white;
        padding: 10px 20px;
        border: none;
        border-radius: 5px;
        text-decoration: none;
        font-weight: bold;
        transition: background 0.3s;
        display: inline-block;
        cursor: pointer;
    }

    .btn-action:hover {
        background: #c0392b;
        color: white;
    }
</style>

<div class="profile-container">
    <!-- 成功消息提示 -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="success-alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }

    <!-- 个人资料头部 -->
    <div class="profile-header">
        <div class="profile-avatar" id="profileAvatar" onclick="showAvatarModal()">
            @if (!string.IsNullOrEmpty(Model.URL))
            {
                <img src="@Model.URL" alt="头像" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
            }
            else
            {
                <i class="fas fa-boxes"></i>
            }
        </div>
        <div style="margin-top: 8px;">
            <button onclick="showAvatarModal()" class="btn btn-sm" style="background: rgba(255,255,255,0.3); color: white; border: none; padding: 5px 15px; border-radius: 5px; cursor: pointer;">
                <i class="fas fa-camera"></i> 修改头像
            </button>
        </div>
        <div class="welcome-text">欢迎回来，@Model.Username！</div>
        <div class="member-info">
            <i class="fas fa-calendar-alt"></i> 注册时间：@(Model.CreatedDate.HasValue ? Model.CreatedDate.Value.ToString("yyyy-MM-dd") : "-")
            @if (Model.LastLoginDate.HasValue)
            {
                <span style="margin-left: 20px;">
                    <i class="fas fa-sign-in-alt"></i> 最后登录：@Model.LastLoginDate.Value.ToString("yyyy-MM-dd HH:mm")
                </span>
            }
        </div>
    </div>

    <!-- 用户信息详情 -->
    <div class="user-info-section">
        <div class="info-title">
            <i class="fas fa-info-circle"></i> 账户信息
        </div>
        <div class="info-item">
            <span class="info-label">用户名</span>
            <span class="info-value">@Model.Username</span>
        </div>
        <div class="info-item">
            <span class="info-label">姓名</span>
            <span class="info-value">@(Model.FullName ?? "-")</span>
        </div>
        <div class="info-item">
            <span class="info-label">手机号码</span>
            <span class="info-value">@Model.PhoneNumber</span>
        </div>
        <div class="info-item">
            <span class="info-label">身份证号</span>
            <span class="info-value">@(Model.IDNumber ?? "-")</span>
        </div>
        <div class="info-item">
            <span class="info-label">基地名称</span>
            <span class="info-value">@(Model.SortingCenterName ?? "-")</span>
        </div>
        <div class="info-item">
            <span class="info-label">当前状态</span>
            <span class="info-value">@Model.CurrentStatus</span>
        </div>
        <div class="info-item">
            <span class="info-label">工作人员ID</span>
            <span class="info-value">@Model.WorkerID</span>
        </div>
        <div class="info-item">
            <span class="info-label">注册时间</span>
            <span class="info-value">@(Model.CreatedDate.HasValue ? Model.CreatedDate.Value.ToString("yyyy-MM-dd HH:mm") : "-")</span>
        </div>
        @if (Model.LastLoginDate.HasValue)
        {
            <div class="info-item">
                <span class="info-label">最后登录</span>
                <span class="info-value">@Model.LastLoginDate.Value.ToString("yyyy-MM-dd HH:mm")</span>
            </div>
        }
    </div>
</div>

<!-- Anti-Forgery Token for AJAX -->
@Html.AntiForgeryToken()

<!-- 头像管理模态框 -->
<div id="avatarModal" class="unified-modal">
    <div class="unified-modal-content">
        <div class="unified-modal-header">
            <h3 class="unified-modal-title"><i class="fas fa-image"></i> 头像管理</h3>
            <button onclick="closeAvatarModal()" class="unified-modal-close">&times;</button>
        </div>

        <!-- 上传头像区域 -->
        <div style="padding: 20px; border: 2px dashed #e74c3c; border-radius: 10px; text-align: center; margin-bottom: 20px;">
            <i class="fas fa-cloud-upload-alt" style="font-size: 48px; color: #e74c3c;"></i>
            <h4>上传自定义头像</h4>
            <p style="color: #666; font-size: 14px;">支持 JPG、PNG、GIF、BMP 格式，文件大小不超过 5MB</p>
            <input type="file" id="avatarFileInput" accept="image/*" style="display: none;" onchange="uploadAvatar()" />
            <button onclick="document.getElementById('avatarFileInput').click()" class="btn-action" style="margin-top: 10px;">
                <i class="fas fa-folder-open"></i> 选择图片
            </button>
        </div>

        <!-- 默认头像选择 -->
        <div>
            <h4 style="margin-bottom: 15px;"><i class="fas fa-user-circle"></i> 选择默认头像</h4>
            <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px;">
                @for (int i = 1; i <= 5; i++)
                {
                    <div onclick="selectDefaultAvatar('avatar@(i).svg')" style="cursor: pointer; text-align: center; transition: transform 0.3s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                        <img src="/Uploads/Avatars/Default/avatar@(i).svg" alt="默认头像@(i)" style="width: 80px; height: 80px; border-radius: 50%; border: 3px solid transparent; transition: border-color 0.3s;" onmouseover="this.style.borderColor='#e74c3c'" onmouseout="this.style.borderColor='transparent'" />
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            setTimeout(function () {
                $('.success-alert').fadeOut('slow');
            }, 5000);
        });

        function showAvatarModal() {
            document.getElementById('avatarModal').classList.add('show');
        }

        function closeAvatarModal() {
            document.getElementById('avatarModal').classList.remove('show');
        }

        function uploadAvatar() {
            var fileInput = document.getElementById('avatarFileInput');
            var file = fileInput.files[0];
            if (!file) return;

            var allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/bmp'];
            if (!allowedTypes.includes(file.type)) {
                alert('只支持 JPG、PNG、GIF、BMP 格式的图片');
                fileInput.value = '';
                return;
            }
            if (file.size > 5 * 1024 * 1024) {
                alert('图片大小不能超过 5MB');
                fileInput.value = '';
                return;
            }

            var formData = new FormData();
            formData.append('avatarFile', file);
            formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

            $.ajax({
                url: '@Url.Action("UploadStaffAvatar", "Staff")',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (response) {
                    if (response.success) {
                        updateAvatarDisplay(response.avatarUrl);
                        closeAvatarModal();
                        alert('头像上传成功！');
                    } else {
                        alert(response.message || '上传失败，请重试');
                    }
                },
                error: function () {
                    alert('上传失败，请检查网络连接');
                },
                complete: function () {
                    fileInput.value = '';
                }
            });
        }

        function selectDefaultAvatar(avatarName) {
            if (!confirm('确定要使用这个默认头像吗？')) return;

            $.ajax({
                url: '@Url.Action("SetStaffDefaultAvatar", "Staff")',
                type: 'POST',
                data: {
                    avatarName: avatarName,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        updateAvatarDisplay(response.avatarUrl);
                        closeAvatarModal();
                        alert('默认头像设置成功！');
                    } else {
                        alert(response.message || '设置失败，请重试');
                    }
                },
                error: function () {
                    alert('设置失败，请检查网络连接');
                }
            });
        }

        function updateAvatarDisplay(avatarUrl) {
            var avatarDiv = document.getElementById('profileAvatar');
            avatarDiv.innerHTML = '';
            var img = document.createElement('img');
            img.src = avatarUrl;
            img.alt = '头像';
            img.style.cssText = 'width: 100%; height: 100%; border-radius: 50%; object-fit: cover;';
            avatarDiv.appendChild(img);
        }

        document.getElementById('avatarModal').addEventListener('click', function (e) {
            if (e.target === this) closeAvatarModal();
        });
    </script>
}
