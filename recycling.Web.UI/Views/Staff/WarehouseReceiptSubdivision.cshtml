@model recycling.Model.WarehouseReceiptSubdivisionViewModel
@using Newtonsoft.Json
@{
    ViewBag.Title = "入库单细分";
    Layout = "~/Views/Shared/_SortingCenterWorkerLayout.cshtml";
}

@Html.AntiForgeryToken()

<style>
    .subdivision-container { max-width: 1200px; margin: 0 auto; padding: 20px; }
    .card { background: #fff; border-radius: 10px; box-shadow: 0 2px 10px rgba(0,0,0,.06); margin-bottom: 20px; }
    .card-header { padding: 16px 20px; border-bottom: 1px solid #eee; font-weight: 600; color: #2c3e50; }
    .card-body { padding: 20px; }
    .info-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; }
    .info-item { background: #f8f9fa; border-radius: 8px; padding: 10px; }
    .info-label { color: #666; font-size: 12px; }
    .info-value { color: #2c3e50; font-weight: 600; margin-top: 4px; }
    .category-block { border: 1px solid #e6e6e6; border-radius: 8px; margin-bottom: 16px; }
    .category-header { padding: 12px 14px; background: #f8fbff; border-bottom: 1px solid #e6e6e6; display: flex; justify-content: space-between; align-items: center; }
    .category-title { font-weight: 600; color: #2c3e50; }
    .category-target { color: #555; font-size: 13px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 10px; border-bottom: 1px solid #f0f0f0; text-align: left; }
    th { color: #444; background: #fafafa; }
    .text-right { text-align: right; }
    .weight-input { width: 120px; text-align: right; }
    .status-ok { color: #27ae60; font-weight: 600; }
    .status-error { color: #e74c3c; font-weight: 600; }
    .actions { display: flex; justify-content: space-between; margin-top: 20px; }
    .btn { border: none; border-radius: 6px; padding: 10px 16px; cursor: pointer; }
    .btn-back { background: #95a5a6; color: #fff; }
    .btn-save { background: #27ae60; color: #fff; }
    .btn-save:disabled { background: #bdc3c7; cursor: not-allowed; }
    .sub-input-group { display: flex; gap: 8px; align-items: center; }
    .sub-input-group .sub-select { flex: 1; min-width: 140px; }
    .sub-input-group .manual-sub-name { flex: 1; min-width: 140px; }
    .sub-weight-row { margin-top: 8px; }
    .sub-weight-row .weight-input { width: 180px; }
    .row-action-btn { min-width: 30px; padding: 4px 8px; font-weight: 700; }
    .row-action-btn:disabled { opacity: .5; cursor: not-allowed; }
    .category-footer { padding: 10px 12px; border-top: 1px solid #f0f0f0; color: #444; font-weight: 600; }
    .row-error { color: #e74c3c; font-size: 12px; margin-top: 4px; display: none; }
    @@media (max-width: 992px) { .info-grid { grid-template-columns: repeat(2,1fr);} }
</style>

<div class="subdivision-container">
    <div class="card">
        <div class="card-header">入库单细分</div>
        <div class="card-body">
            <div class="info-grid">
                <div class="info-item"><div class="info-label">入库单号</div><div class="info-value">@Model.ReceiptNumber</div></div>
                <div class="info-item"><div class="info-label">状态</div><div class="info-value">@Model.Status</div></div>
                <div class="info-item"><div class="info-label">入库总重量(kg)</div><div class="info-value" id="receiptTotalWeight">@Model.TotalWeight.ToString("F2")</div></div>
                <div class="info-item"><div class="info-label">细分状态</div><div class="info-value">@(Model.IsRefined ? "已细分" : "未细分")</div></div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">按大类细分（每个大类细分重量之和不可超过原重量，可因杂质减少）</div>
        <div class="card-body" id="subdivisionArea"></div>
    </div>

    <div class="card">
        <div class="card-header">汇总</div>
        <div class="card-body">
            <div>细分总重量：<span id="totalWeightText">0.00</span> kg</div>
            <div>细分总价值：<span id="totalPriceText">¥0.00</span></div>
            <div id="overallStatus" class="status-error">请完成细分并确保各大类及总重量不超重</div>
            <div class="actions">
                <button class="btn btn-back" onclick="goBack()">返回仓库管理</button>
                <button id="saveBtn" class="btn btn-save" onclick="saveSubdivision()" disabled>保存细分</button>
            </div>
        </div>
    </div>
</div>

<script>
    var receiptId = @Model.ReceiptID;
    var receiptTotalWeight = @Model.TotalWeight.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    var weightTolerance = @Model.ValidationTolerance.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    var parentCategories = @Html.Raw(JsonConvert.SerializeObject(Model.Categories));
    var templateGroups = @Html.Raw(JsonConvert.SerializeObject(Model.SubdivisionTemplates));
    var existingSubdivisions = @Html.Raw(JsonConvert.SerializeObject(Model.ExistingSubdivisions));
    var maxSubCategoryCount = 5;

    function goBack() { window.location.href = '@Url.Action("BaseWarehouseManagement", "Staff")'; }
    function escapeHtml(v) { return $('<div>').text(v || '').html(); }

    function findTemplateOptions(parentKey) {
        for (var i = 0; i < templateGroups.length; i++) {
            if (templateGroups[i].ParentCategoryKey === parentKey) return templateGroups[i].Options || [];
        }
        return [];
    }

    function findOptionBySubKey(parentKey, options, selectedSubKey) {
        var selectedNormalized = stripParentPrefixFromSubKey(parentKey, selectedSubKey);
        for (var i = 0; i < (options || []).length; i++) {
            var current = options[i];
            var currentNormalized = stripParentPrefixFromSubKey(parentKey, current.SubCategoryKey);
            if (currentNormalized === selectedNormalized) {
                return current;
            }
        }
        return null;
    }

    function findExistingRowsByParent(parentKey) {
        var rows = [];
        var normalizedParentKey = (parentKey || '').toString().toLowerCase();
        for (var i = 0; i < (existingSubdivisions || []).length; i++) {
            var item = existingSubdivisions[i];
            if (!item) continue;
            var itemParentKey = (item.ParentCategoryKey || '').toString().toLowerCase();
            if (itemParentKey === normalizedParentKey && Number(item.Weight || 0) > 0) {
                rows.push(item);
            }
        }
        return rows;
    }

    function buildCategorySelect(options, selectedKey) {
        var html = '<select class="sub-select" onchange="onSubCategoryChanged(this)">';
        if (!options || options.length === 0) {
            html += '<option value="">暂无下拉选项，请在下方手动输入</option>';
        } else {
            html += '<option value="">请选择细分类</option>';
        }
        for (var i = 0; i < options.length; i++) {
            var opt = options[i];
            var key = (opt.SubCategoryKey || ('sub' + i));
            var selected = selectedKey === key ? ' selected' : '';
            html += '<option value="' + escapeHtml(key) + '" data-name="' + escapeHtml(opt.SubCategoryName || key) + '" data-price="' + Number(opt.PricePerKg || 0).toFixed(2) + '"' + selected + '>' +
                escapeHtml(opt.SubCategoryName || key) + '</option>';
        }
        html += '</select>';
        return html;
    }

    function stripParentPrefixFromSubKey(parentKey, subKey) {
        var normalizedParentKey = (parentKey || '').toString().toLowerCase();
        var normalizedSubKey = (subKey || '').toString().toLowerCase();
        if (!normalizedParentKey || !normalizedSubKey) return normalizedSubKey;
        var prefix = normalizedParentKey + '_';
        if (normalizedSubKey.indexOf(prefix) === 0) return normalizedSubKey.substring(prefix.length);
        return normalizedSubKey;
    }

    function createRow(parentKey, parentName, options, defaultWeight, selectedSubKey, manualSubName, manualPricePerKg) {
        var selectedTemplateOption = findOptionBySubKey(parentKey, options, selectedSubKey);

        var isManual = !!selectedSubKey && !selectedTemplateOption;
        var selectedValue = isManual ? '' : ((selectedTemplateOption && selectedTemplateOption.SubCategoryKey) || '');
        var defaultPrice = options && options.length > 0 ? Number(options[0].PricePerKg || 1) : 1;
        var ppk = Number(isManual ? (manualPricePerKg || defaultPrice) : ((selectedTemplateOption && selectedTemplateOption.PricePerKg) || defaultPrice));
        var rowWeight = Number(defaultWeight || 0);
        var amount = rowWeight * ppk;
        var row = '' +
            '<tr class="sub-row" data-parent-key="' + escapeHtml(parentKey) + '" data-parent-name="' + escapeHtml(parentName) + '">' +
            '<td>' +
            '<div class="sub-input-group">' +
            buildCategorySelect(options || [], selectedValue) +
            '<input type="text" class="manual-sub-name" maxlength="50" placeholder="无下拉项时可手动输入细类" value="' + escapeHtml(manualSubName || '') + '" oninput="recalc()" />' +
            '</div>' +
            '<div class="sub-weight-row"><input class="weight-input" type="number" min="0" step="0.01" value="' + rowWeight.toFixed(2) + '" data-price-per-kg="' + ppk.toFixed(2) + '" oninput="recalc()" placeholder="请输入重量(kg)" /></div>' +
            '<div class="row-error"></div>' +
            '</td>' +
            '<td class="text-right"><span class="price-per-kg">' + ppk.toFixed(2) + '</span></td>' +
            '<td class="text-right amount-cell">¥' + amount.toFixed(2) + '</td>' +
            '<td class="text-right">' +
            '<button type="button" class="btn btn-save row-action-btn btn-plus" onclick="addSubRow(this)">＋</button> ' +
            '<button type="button" class="btn btn-back row-action-btn btn-minus" onclick="removeSubRow(this)">－</button>' +
            '</td>' +
            '</tr>';
        return row;
    }

    function onSubCategoryChanged(selectEl) {
        var row = $(selectEl).closest('tr');
        var val = $(selectEl).val();
        var input = row.find('.weight-input');
        var selected = $(selectEl).find('option:selected');
        var defaultPrice = Number(row.closest('.category-block').data('default-price') || 1);
        var ppk = Number(selected.data('price') || defaultPrice);

        if (!val) ppk = defaultPrice;
        input.data('price-per-kg', ppk.toFixed(2));
        row.find('.price-per-kg').text(ppk.toFixed(2));
        recalc();
    }

    function addSubRow(btn) {
        var block = $(btn).closest('.category-block');
        var rows = block.find('tbody tr.sub-row');
        if (rows.length >= maxSubCategoryCount) {
            alert('每个大类最多添加 ' + maxSubCategoryCount + ' 个细类');
            return;
        }
        var options = block.data('template-options') || [];
        var parentKey = block.data('parent-key');
        var parentName = block.data('parent-name');
        block.find('tbody').append(createRow(parentKey, parentName, options, 0));
        updateRowActionButtons(block);
        recalc();
    }

    function removeSubRow(btn) {
        var block = $(btn).closest('.category-block');
        if (block.find('tbody tr.sub-row').length <= 1) {
            alert('每个大类至少保留1个细分类输入行');
            return;
        }
        $(btn).closest('tr').remove();
        updateRowActionButtons(block);
        recalc();
    }

    function updateRowActionButtons(block) {
        var rows = block.find('tbody tr.sub-row');
        var count = rows.length;
        rows.each(function (idx) {
            var row = $(this);
            var plusBtn = row.find('.btn-plus');
            var minusBtn = row.find('.btn-minus');
            plusBtn.prop('disabled', count >= maxSubCategoryCount);
            if (idx === 0 || count <= 1) {
                minusBtn.prop('disabled', true);
                minusBtn.css('visibility', 'hidden');
            } else {
                minusBtn.prop('disabled', false);
                minusBtn.css('visibility', 'visible');
            }
        });
    }

    function renderCategories() {
        var area = $('#subdivisionArea');
        area.empty();

        for (var i = 0; i < parentCategories.length; i++) {
            var parent = parentCategories[i];
            var options = findTemplateOptions(parent.CategoryKey);
            if (!options) options = [];

            var defaultPrice = options.length > 0 ? Number(options[0].PricePerKg || 1) : 1;
            var parentKey = (parent.CategoryKey || '').toString();
            var parentName = (parent.CategoryName || '').toString();
            var parentExistingRows = findExistingRowsByParent(parentKey);
            var rowsHtml = '';
            if (parentExistingRows.length > 0) {
                for (var r = 0; r < parentExistingRows.length; r++) {
                    var existing = parentExistingRows[r];
                    rowsHtml += createRow(
                        parentKey,
                        parentName,
                        options,
                        existing.Weight || 0,
                        existing.CategoryKey || '',
                        existing.CategoryName || '',
                        existing.PricePerKg || defaultPrice);
                }
            } else {
                rowsHtml = createRow(parentKey, parentName, options, parent.Weight || 0);
            }

            var block = '' +
                '<div class="category-block" data-parent-key="' + escapeHtml(parentKey) + '" data-parent-name="' + escapeHtml(parentName) + '" data-target-weight="' + Number(parent.Weight || 0).toFixed(2) + '" data-default-price="' + defaultPrice.toFixed(2) + '">' +
                '<div class="category-header">' +
                '<div class="category-title">' + escapeHtml(parentName) + '</div>' +
                '<div class="category-target">原始重量：' + Number(parent.Weight || 0).toFixed(2) + ' kg | 当前：<span class="current-weight">0.00</span> kg | 余量：<span class="diff-weight">0.00</span> kg | <span class="category-status status-error">待计算</span></div>' +
                '</div>' +
                '<div><table><thead><tr><th>细分类组合(下拉/手动 + 下方重量)</th><th class="text-right">单价(元/kg)</th><th class="text-right">金额(元)</th><th class="text-right">操作</th></tr></thead>' +
                '<tbody>' + rowsHtml + '</tbody></table></div>' +
                '<div class="category-footer">细类总重：<span class="category-total-weight">0.00</span> kg（需 ≤ 原始重量）</div>' +
                '</div>';

            var jqBlock = $(block);
            jqBlock.data('template-options', options);
            area.append(jqBlock);
            updateRowActionButtons(jqBlock);
        }

        recalc();
    }

    function getSubCategoryData(row) {
        var parentKey = row.data('parent-key');
        var select = row.find('.sub-select');
        var selectedVal = select.val();
        var selectedOption = select.find('option:selected');
        var subName = '';
        var subKey = '';
        var manualName = (row.find('.manual-sub-name').val() || '').trim();
        var hasSelectValue = !!(selectedVal || '').toString().trim();
        var hasManualValue = !!manualName;

        if (hasSelectValue && hasManualValue) {
            return { isValid: false, errorMessage: "下拉细分类和手动输入不能同时填写", subKey: "", subName: "" };
        }
        if (!hasSelectValue && !hasManualValue) {
            return { isValid: false, errorMessage: "请填写下拉细分类或手动细类中的一项", subKey: "", subName: "" };
        }

        if (hasManualValue) {
            subName = manualName;
            var index = row.index() + 1;
            subKey = 'manual' + index;
        } else {
            subName = (selectedOption.data('name') || selectedOption.text() || '').toString().trim();
            subKey = (selectedVal || '').toString().trim();
        }

        if (!subKey) subKey = 'sub';
        return {
            isValid: true,
            errorMessage: "",
            subKey: (parentKey + '_' + subKey).substring(0, 50),
            subName: subName
        };
    }

    function recalc() {
        var totalWeight = 0;
        var totalPrice = 0;
        var allCategoryValid = true;

        $('.category-block').each(function () {
            var block = $(this);
            var target = Number(block.data('target-weight') || 0);
            var current = 0;
            var validSubCount = 0;
            var hasInvalidSubName = false;

            block.find('tbody tr').each(function () {
                var row = $(this);
                var input = row.find('input.weight-input');
                var weight = Number(input.val() || 0);
                if (weight < 0) weight = 0;
                var ppk = Number(input.data('price-per-kg') || 0);
                var amount = weight * ppk;

                if (weight > 0) {
                    var subData = getSubCategoryData(row);
                    var rowError = row.find('.row-error');
                    if (!subData.isValid || !subData.subName) {
                        hasInvalidSubName = true;
                        rowError.text(subData.errorMessage || '细分类填写不完整').show();
                    } else {
                        validSubCount++;
                        rowError.hide().text('');
                    }
                } else {
                    row.find('.row-error').hide().text('');
                }

                current += weight;
                totalWeight += weight;
                totalPrice += amount;
                row.find('.amount-cell').text('¥' + amount.toFixed(2));
            });

            var diff = target - current;
            block.find('.current-weight').text(current.toFixed(2));
            block.find('.diff-weight').text(diff.toFixed(2));
            block.find('.category-total-weight').text(current.toFixed(2));

            var overWeight = current - target > Number(weightTolerance || 0);
            var categoryValid = !overWeight && !hasInvalidSubName && validSubCount > 0;
            block.find('.diff-weight').removeClass('status-ok status-error').addClass(overWeight ? 'status-error' : 'status-ok');
            block.find('.category-status').removeClass('status-ok status-error')
                .addClass(categoryValid ? 'status-ok' : 'status-error')
                .text(categoryValid ? '校验通过' : (overWeight ? '超出原始重量' : '请完善细类名称和重量'));

            if (!categoryValid) allCategoryValid = false;
        });

        $('#totalWeightText').text(totalWeight.toFixed(2));
        $('#totalPriceText').text('¥' + totalPrice.toFixed(2));

        var receiptWeight = Number(receiptTotalWeight || 0);
        var overallValid = allCategoryValid && (totalWeight - receiptWeight) <= Number(weightTolerance || 0) && totalWeight > 0;
        $('#overallStatus').removeClass('status-ok status-error').addClass(overallValid ? 'status-ok' : 'status-error')
            .text(overallValid ? '校验通过，可保存细分' : '请完成细分并确保各大类及总重量不超重');
        $('#saveBtn').prop('disabled', !overallValid);
    }

    function collectSubdivisionData() {
        var items = [];
        var hasError = false;

        $('.category-block').each(function () {
            var parentBlock = $(this);
            var parentKey = (parentBlock.data('parent-key') || '').toString();
            var parentName = (parentBlock.data('parent-name') || '').toString();

            parentBlock.find('.sub-row').each(function () {
                var row = $(this);
                var weight = Number(row.find('input.weight-input').val() || 0);
                if (weight <= 0) return;

                var subData = getSubCategoryData(row);
                if (!subData.isValid || !subData.subName) {
                    hasError = true;
                    row.find('.row-error').text(subData.errorMessage || '细分类填写不完整').show();
                    return;
                }

                var pricePerKg = Number(row.find('input.weight-input').data('price-per-kg') || 0);
                items.push({
                    categoryKey: subData.subKey,
                    categoryName: subData.subName.substring(0, 50),
                    parentCategoryKey: parentKey,
                    parentCategoryName: parentName,
                    weight: Number(weight.toFixed(2)),
                    pricePerKg: Number(pricePerKg.toFixed(2)),
                    totalAmount: Number((weight * pricePerKg).toFixed(2))
                });
            });
        });

        if (hasError) {
            alert('存在已填写重量但未填写细类名称的数据，请检查各大类中的手动输入行');
            return null;
        }
        return items;
    }

    function saveSubdivision() {
        recalc();
        var data = collectSubdivisionData();
        if (!data || data.length === 0) {
            alert('请至少填写一条细分明细');
            return;
        }

        $.ajax({
            url: '@Url.Action("SaveWarehouseReceiptSubdivision", "Staff")',
            type: 'POST',
            dataType: 'json',
            data: {
                receiptId: receiptId,
                subdivisionsJson: JSON.stringify(data),
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            },
            success: function (response) {
                if (response.success) {
                    alert('细分保存成功，返回后可执行入库。');
                    goBack();
                } else {
                    alert('保存失败：' + (response.message || '未知错误'));
                }
            },
            error: function () { alert('保存失败，请稍后重试'); }
        });
    }

    $(document).ready(function () { renderCategories(); });
</script>
