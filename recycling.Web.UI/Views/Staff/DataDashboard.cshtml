@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    <script>
        var charts = {};

        Chart.defaults.color = 'rgba(0,0,0,0.5)';
        Chart.defaults.borderColor = 'rgba(0,0,0,0.08)';

        $(document).ready(function () {
            loadDashboardData();
        });

        function loadDashboardData() {
            $('#dbLoading').show();
            $.ajax({
                url: '@Url.Action("GetDashboardStatistics", "Staff")',
                type: 'GET',
                dataType: 'json',
                success: function (response) {
                    if (response.success) {
                        updateDashboard(response.data);
                    } else {
                        showFallbackDashboard();
                    }
                },
                error: function () {
                    showFallbackDashboard();
                },
                complete: function () {
                    $('#dbLoading').hide();
                }
            });
        }

        function v(val, dec) {
            if (val === null || val === undefined) return '0';
            dec = dec || 0;
            return parseFloat(val).toLocaleString('zh-CN', { minimumFractionDigits: dec, maximumFractionDigits: dec });
        }

        function showFallbackDashboard() {
            var now = new Date().toLocaleString('zh-CN');
            $('#dbLastUpdate').text('更新: ' + now);
            $('#dbFooterTime').text(now);

            $('#ordersToday, #completedToday, #newUsersToday, #activeWeek, #pendingTotal, #pendingFbk, #pendingOrd').text('0');
            $('#revenueToday').text('¥0');
            $('#weightToday').text('0');

            $('#totalOrders, #ordersMonth, #ordersWeek').text('0');
            $('#totalRevenue').text('¥0');
            $('#revenueMonth, #revenueWeek').text('0');
            $('#totalWeight, #weightMonth, #weightWeek').text('0');
            $('#totalUsers, #newUsersMonth').text('0');

            $('#pUsers, #pUsersActive, #pRecyclers, #pRecyclersAvail, #pTransporters, #pTransportersAvail').text('0');
            $('#pSortingWorkers, #pSortingActive, #pAdmins, #pAdminsActive, #pSuperAdmins, #totalPersonnel').text('0');

            $('#pipePending, #pipeProgress, #pipeCompleted, #pipeCancelled').text('0');
            $('#tpPending, #tpAccepted, #tpInTransit, #tpCompleted').text('0');

            $('#completionRate, #feedbackRate, #warehouseRate').text('0%');
            $('#avgRating').text('0.0');

            $('#cancelTotal, #cancelRecycler, #cancelSystem').text('0');

            $('#sysAdmins, #sysAdminsActive, #sysSuperAdmins, #sysReviews').text('0');
            $('#sysAvgReview, #sysRecyclerRating').text('0.00');
            $('#sysFeedbacks, #sysProcessedFb, #sysUnreadNotif').text('0');
            $('#sysWReceipts, #sysWPending, #sysWProcessed').text('0');
            $('#sysWWeight').text('0 kg');
            $('#sysItemsProcessed').text('0');
            $('#sysWeightProcessed').text('0 kg');
            $('#sysSortingActive').text('0');

            $('#tblRecyclers tbody').html('<tr><td colspan="4" style="text-align:center;color:rgba(0,0,0,0.3);">暂无数据</td></tr>');
            $('#tblUsers tbody').html('<tr><td colspan="4" style="text-align:center;color:rgba(0,0,0,0.3);">暂无数据</td></tr>');
            $('#tblRegion tbody').html('<tr><td colspan="3" style="text-align:center;color:rgba(0,0,0,0.3);">暂无数据</td></tr>');
            $('#tblInventory tbody').html('<tr><td colspan="2" style="text-align:center;color:rgba(0,0,0,0.3);">暂无数据</td></tr>');
        }

        function updateDashboard(d) {
            var now = new Date().toLocaleString('zh-CN');
            $('#dbLastUpdate').text('更新: ' + now);
            $('#dbFooterTime').text(now);

            $('#ordersToday').text(v(d.OrdersToday));
            $('#completedToday').text(v(d.CompletedOrdersToday));
            $('#revenueToday').text('¥' + v(d.RevenueToday, 2));
            $('#weightToday').text(v(d.WeightToday, 1));
            $('#newUsersToday').text(v(d.NewUsersToday));
            $('#activeWeek').text(v(d.ActiveUsersThisWeek));
            var pt = (parseInt(d.PendingFeedbacks) || 0) + (parseInt(d.PendingOrders) || 0);
            $('#pendingTotal').text(v(pt));
            $('#pendingFbk').text(v(d.PendingFeedbacks));
            $('#pendingOrd').text(v(d.PendingOrders));

            $('#totalOrders').text(v(d.TotalOrders));
            $('#ordersMonth').text(v(d.OrdersThisMonth));
            $('#ordersWeek').text(v(d.OrdersThisWeek));
            $('#totalRevenue').text('¥' + v(d.TotalRevenue, 2));
            $('#revenueMonth').text(v(d.RevenueThisMonth, 2));
            $('#revenueWeek').text(v(d.RevenueThisWeek, 2));
            $('#totalWeight').text(v(d.TotalWeightCollected, 1));
            $('#weightMonth').text(v(d.WeightThisMonth, 1));
            $('#weightWeek').text(v(d.WeightThisWeek, 1));
            $('#totalUsers').text(v(d.TotalUsers));
            $('#newUsersMonth').text(v(d.NewUsersThisMonth));

            $('#pUsers').text(v(d.TotalUsers));
            $('#pUsersActive').text(v(d.ActiveUsersThisWeek));
            $('#pRecyclers').text(v(d.TotalRecyclers));
            $('#pRecyclersAvail').text(v(d.AvailableRecyclers));
            $('#pTransporters').text(v(d.TotalTransporters));
            $('#pTransportersAvail').text(v(d.AvailableTransporters));
            $('#pSortingWorkers').text(v(d.TotalSortingWorkers));
            $('#pSortingActive').text(v(d.ActiveSortingWorkers));
            $('#pAdmins').text(v(d.TotalAdmins));
            $('#pAdminsActive').text(v(d.ActiveAdmins));
            $('#pSuperAdmins').text(v(d.TotalSuperAdmins));
            $('#totalPersonnel').text(v(d.TotalPersonnel));

            $('#pipePending').text(v(d.PendingOrders));
            $('#pipeProgress').text(v(d.InProgressOrders));
            $('#pipeCompleted').text(v(d.CompletedOrders));
            var allCancelled = (parseInt(d.CancelledOrders) || 0) + (parseInt(d.RecyclerCancelledOrders) || 0) + (parseInt(d.SystemExpiredOrders) || 0);
            $('#pipeCancelled').text(v(allCancelled));

            $('#tpPending').text(v(d.PendingTransportOrders));
            $('#tpAccepted').text(v(d.AcceptedTransportOrders));
            $('#tpInTransit').text(v(d.InTransitOrders));
            $('#tpCompleted').text(v(d.CompletedTransportOrders));

            var cr = parseFloat(d.OrderCompletionRate) || 0;
            $('#completionRate').text(cr.toFixed(1) + '%');
            drawRing('ringCompletion', cr, '#6366f1');

            var totalFb = parseInt(d.TotalFeedbacks) || 0;
            var processedFb = parseInt(d.ProcessedFeedbacks) || 0;
            var fbRate = totalFb > 0 ? (processedFb / totalFb * 100) : 0;
            $('#feedbackRate').text(fbRate.toFixed(1) + '%');
            drawRing('ringFeedback', fbRate, '#0891b2');

            var totalWR = parseInt(d.TotalWarehouseReceipts) || 0;
            var processedWR = parseInt(d.ProcessedWarehouseReceipts) || 0;
            var wrRate = totalWR > 0 ? (processedWR / totalWR * 100) : 0;
            $('#warehouseRate').text(wrRate.toFixed(1) + '%');
            drawRing('ringWarehouse', wrRate, '#059669');

            var ar = parseFloat(d.AverageRecyclerRating) || 0;
            $('#avgRating').text(ar.toFixed(2));
            $('#avgRatingStars').html(getStarHtml(ar));

            $('#cancelTotal').text(v(allCancelled));
            $('#cancelRecycler').text(v(d.RecyclerCancelledOrders));
            $('#cancelSystem').text(v(d.SystemExpiredOrders));

            renderOrderTrend(d.OrderTrend);
            renderOrderStatus(d.OrderStatusDistribution);
            renderMonthly(d.MonthlyOrderTrend, d.RevenueWeightTrend);
            renderCategory(d.CategoryDistribution);
            renderTransportStatus(d.TransportStatusDistribution);
            renderUserReg(d.UserRegistrationTrend);

            renderRecyclerTable(d.TopRecyclers);
            renderUserTable(d.TopUsers);
            renderRegionTable(d.RegionDistribution);
            renderInventoryTable(d.InventoryStats);

            $('#sysAdmins').text(v(d.TotalAdmins));
            $('#sysAdminsActive').text(v(d.ActiveAdmins));
            $('#sysSuperAdmins').text(v(d.TotalSuperAdmins));
            $('#sysReviews').text(v(d.TotalReviews));
            $('#sysAvgReview').text(parseFloat(d.AverageReviewRating || 0).toFixed(2) + ' 分');
            $('#sysRecyclerRating').text(parseFloat(d.AverageRecyclerRating || 0).toFixed(2) + ' 分');
            $('#sysFeedbacks').text(v(d.TotalFeedbacks));
            $('#sysProcessedFb').text(v(d.ProcessedFeedbacks));
            $('#sysUnreadNotif').text(v(d.UnreadNotifications));

            $('#sysWReceipts').text(v(d.TotalWarehouseReceipts));
            $('#sysWPending').text(v(d.PendingWarehouseReceipts));
            $('#sysWProcessed').text(v(d.ProcessedWarehouseReceipts));
            $('#sysWWeight').text(v(d.TotalWarehouseWeight, 2) + ' kg');

            $('#sysItemsProcessed').text(v(d.TotalItemsProcessed));
            $('#sysWeightProcessed').text(v(d.TotalWeightProcessed, 2) + ' kg');
            $('#sysSortingActive').text(v(d.ActiveSortingWorkers));
        }

        function drawRing(canvasId, percent, color) {
            var canvas = document.getElementById(canvasId);
            if (!canvas) return;
            var ctx = canvas.getContext('2d');
            var size = 80;
            canvas.width = size * 2;
            canvas.height = size * 2;
            canvas.style.width = size + 'px';
            canvas.style.height = size + 'px';
            var cx = size, cy = size, r = size - 12, lw = 8;

            ctx.clearRect(0, 0, size * 2, size * 2);
            ctx.beginPath();
            ctx.arc(cx, cy, r, 0, Math.PI * 2);
            ctx.strokeStyle = 'rgba(0,0,0,0.08)';
            ctx.lineWidth = lw;
            ctx.stroke();
            if (percent > 0) {
                ctx.beginPath();
                ctx.arc(cx, cy, r, -Math.PI / 2, -Math.PI / 2 + (Math.PI * 2 * Math.min(percent, 100) / 100));
                ctx.strokeStyle = color;
                ctx.lineWidth = lw;
                ctx.lineCap = 'round';
                ctx.stroke();
            }
        }

        function getStarHtml(rating) {
            var full = Math.floor(rating);
            var half = (rating - full) >= 0.5;
            var empty = 5 - full - (half ? 1 : 0);
            var h = '';
            for (var i = 0; i < full; i++) h += '<i class="fas fa-star"></i>';
            if (half) h += '<i class="fas fa-star-half-alt"></i>';
            for (var i = 0; i < empty; i++) h += '<i class="far fa-star"></i>';
            return h;
        }

        function renderOrderTrend(data) {
            var labels = data ? data.map(function (d) { return d.Date; }) : [];
            var values = data ? data.map(function (d) { return d.Count; }) : [];
            var today = new Date();
            var fL = [], fV = [];
            for (var i = 6; i >= 0; i--) {
                var dt = new Date(today); dt.setDate(dt.getDate() - i);
                var ds = (dt.getMonth() + 1).toString().padStart(2, '0') + '-' + dt.getDate().toString().padStart(2, '0');
                fL.push(ds);
                var idx = labels.indexOf(ds);
                fV.push(idx >= 0 ? values[idx] : 0);
            }
            destroyChart('chartOrderTrend');
            charts['chartOrderTrend'] = new Chart(document.getElementById('chartOrderTrend'), {
                type: 'bar',
                data: {
                    labels: fL,
                    datasets: [{
                        label: '订单数',
                        data: fV,
                        backgroundColor: createGradient('chartOrderTrend', '#818cf8', '#4f46e5'),
                        borderRadius: 6,
                        borderSkipped: false,
                        barPercentage: 0.6
                    }]
                },
                options: chartOpts(false)
            });
        }

        function renderOrderStatus(data) {
            var labels = data ? data.map(function (d) { return d.Status; }) : [];
            var values = data ? data.map(function (d) { return d.Count; }) : [];
            var colors = ['#6366f1', '#10b981', '#d97706', '#db2777', '#0891b2', '#7c3aed'];
            destroyChart('chartOrderStatus');
            charts['chartOrderStatus'] = new Chart(document.getElementById('chartOrderStatus'), {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: values,
                        backgroundColor: colors.slice(0, labels.length),
                        borderWidth: 0,
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    cutout: '65%',
                    plugins: {
                        legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true, pointStyleWidth: 10, font: { size: 11 } } }
                    }
                }
            });
        }

        function renderMonthly(orderData, revenueData) {
            var labels = orderData ? orderData.map(function (d) { return d.Month; }) : [];
            var orderVals = orderData ? orderData.map(function (d) { return d.Count; }) : [];
            var revLabels = revenueData ? revenueData.map(function (d) { return d.Month; }) : [];
            var revVals = revenueData ? revenueData.map(function (d) { return d.Revenue; }) : [];

            var allLabels = labels.slice();
            revLabels.forEach(function (l) { if (allLabels.indexOf(l) === -1) allLabels.push(l); });
            allLabels.sort();

            var orderMerged = allLabels.map(function (l) { var i = labels.indexOf(l); return i >= 0 ? orderVals[i] : 0; });
            var revMerged = allLabels.map(function (l) { var i = revLabels.indexOf(l); return i >= 0 ? revVals[i] : 0; });

            destroyChart('chartMonthly');
            charts['chartMonthly'] = new Chart(document.getElementById('chartMonthly'), {
                type: 'line',
                data: {
                    labels: allLabels,
                    datasets: [
                        {
                            label: '订单数',
                            data: orderMerged,
                            borderColor: '#6366f1',
                            backgroundColor: 'rgba(99,102,241,0.1)',
                            fill: true,
                            tension: 0.4,
                            pointRadius: 4,
                            pointBackgroundColor: '#6366f1',
                            yAxisID: 'y'
                        },
                        {
                            label: '营收 (¥)',
                            data: revMerged,
                            borderColor: '#059669',
                            backgroundColor: 'rgba(5,150,105,0.08)',
                            fill: true,
                            tension: 0.4,
                            pointRadius: 4,
                            pointBackgroundColor: '#059669',
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: { legend: { labels: { usePointStyle: true, padding: 16, font: { size: 11 } } } },
                    scales: {
                        y: { beginAtZero: true, position: 'left', grid: { color: 'rgba(0,0,0,0.06)' }, ticks: { font: { size: 10 } } },
                        y1: { beginAtZero: true, position: 'right', grid: { drawOnChartArea: false }, ticks: { font: { size: 10 } } },
                        x: { grid: { color: 'rgba(0,0,0,0.06)' }, ticks: { font: { size: 10 } } }
                    }
                }
            });
        }

        function renderCategory(data) {
            var labels = data ? data.map(function (d) { return d.Category; }) : [];
            var values = data ? data.map(function (d) { return d.Count; }) : [];
            var colors = ['#6366f1', '#0891b2', '#10b981', '#d97706', '#db2777', '#7c3aed', '#ef4444', '#0284c7'];
            destroyChart('chartCategory');
            charts['chartCategory'] = new Chart(document.getElementById('chartCategory'), {
                type: 'polarArea',
                data: {
                    labels: labels,
                    datasets: [{
                        data: values,
                        backgroundColor: colors.slice(0, labels.length).map(function (c) { return c + '99'; }),
                        borderColor: colors.slice(0, labels.length),
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'right', labels: { padding: 12, usePointStyle: true, font: { size: 11 } } }
                    },
                    scales: { r: { grid: { color: 'rgba(0,0,0,0.08)' }, ticks: { display: false } } }
                }
            });
        }

        function renderTransportStatus(data) {
            var labels = data ? data.map(function (d) { return d.Status; }) : [];
            var values = data ? data.map(function (d) { return d.Count; }) : [];
            var colors = ['#d97706', '#0891b2', '#6366f1', '#059669'];
            destroyChart('chartTransportStatus');
            charts['chartTransportStatus'] = new Chart(document.getElementById('chartTransportStatus'), {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: values,
                        backgroundColor: colors.slice(0, labels.length),
                        borderWidth: 0,
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    cutout: '65%',
                    plugins: {
                        legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true, pointStyleWidth: 10, font: { size: 11 } } }
                    }
                }
            });
        }

        function renderUserReg(data) {
            var labels = data ? data.map(function (d) { return d.Date; }) : [];
            var values = data ? data.map(function (d) { return d.Count; }) : [];
            destroyChart('chartUserReg');
            charts['chartUserReg'] = new Chart(document.getElementById('chartUserReg'), {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: '新增用户',
                        data: values,
                        borderColor: '#ec4899',
                        backgroundColor: 'rgba(236,72,153,0.1)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 2,
                        pointBackgroundColor: '#ec4899'
                    }]
                },
                options: chartOpts(false)
            });
        }

        function renderRecyclerTable(data) {
            var tbody = $('#tblRecyclers tbody');
            tbody.empty();
            if (!data || data.length === 0) {
                tbody.html('<tr><td colspan="4" style="text-align:center;color:rgba(0,0,0,0.3);">暂无数据</td></tr>');
                return;
            }
            data.forEach(function (item, i) {
                var rc = i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : 'normal';
                var rating = parseFloat(item.Rating || 0).toFixed(1);
                tbody.append('<tr><td><span class="rank-badge ' + rc + '">' + (i + 1) + '</span></td>' +
                    '<td>' + esc(item.Name) + '</td>' +
                    '<td><span class="rating-stars">' + getStarHtml(parseFloat(rating)) + '</span> ' + rating + '</td>' +
                    '<td>' + (item.CompletedOrders || 0) + '</td></tr>');
            });
        }

        function renderUserTable(data) {
            var tbody = $('#tblUsers tbody');
            tbody.empty();
            if (!data || data.length === 0) {
                tbody.html('<tr><td colspan="4" style="text-align:center;color:rgba(0,0,0,0.3);">暂无数据</td></tr>');
                return;
            }
            data.forEach(function (item, i) {
                var rc = i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : 'normal';
                tbody.append('<tr><td><span class="rank-badge ' + rc + '">' + (i + 1) + '</span></td>' +
                    '<td>' + esc(item.Username) + '</td>' +
                    '<td>' + (item.TotalOrders || 0) + '</td>' +
                    '<td>¥' + v(item.TotalSpent, 2) + '</td></tr>');
            });
        }

        function renderRegionTable(data) {
            var tbody = $('#tblRegion tbody');
            tbody.empty();
            if (!data || data.length === 0) {
                tbody.html('<tr><td colspan="3" style="text-align:center;color:rgba(0,0,0,0.3);">暂无数据</td></tr>');
                return;
            }
            data.forEach(function (item, i) {
                var rc = i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : 'normal';
                tbody.append('<tr><td><span class="rank-badge ' + rc + '">' + (i + 1) + '</span></td>' +
                    '<td>' + esc(item.Region) + '</td><td>' + (item.Count || 0) + '</td></tr>');
            });
        }

        function renderInventoryTable(data) {
            var tbody = $('#tblInventory tbody');
            tbody.empty();
            if (!data || data.length === 0) {
                tbody.html('<tr><td colspan="2" style="text-align:center;color:rgba(0,0,0,0.3);">暂无数据</td></tr>');
                return;
            }
            data.forEach(function (item) {
                tbody.append('<tr><td>' + esc(item.CategoryName) + '</td><td>' + v(item.TotalWeight, 2) + '</td></tr>');
            });
        }

        function destroyChart(id) {
            if (charts[id]) { charts[id].destroy(); delete charts[id]; }
        }

        function createGradient(canvasId, c1, c2) {
            var ctx = document.getElementById(canvasId).getContext('2d');
            var g = ctx.createLinearGradient(0, 0, 0, 280);
            g.addColorStop(0, c1);
            g.addColorStop(1, c2);
            return g;
        }

        function chartOpts(showLegend) {
            return {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: !!showLegend } },
                scales: {
                    y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.06)' }, ticks: { font: { size: 10 } } },
                    x: { grid: { color: 'rgba(0,0,0,0.06)' }, ticks: { font: { size: 10 } } }
                }
            };
        }

        function esc(text) {
            if (!text) return '';
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(text));
            return div.innerHTML;
        }
    </script>
}
