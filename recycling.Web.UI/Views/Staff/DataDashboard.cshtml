@{
    ViewBag.Title = "数据看板";
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}

<style>
    .db-wrap {
        background: linear-gradient(135deg, #eef1f8 0%, #e4e9f2 50%, #f0ecf9 100%);
        min-height: 100vh;
        padding: 24px;
        margin: -20px -15px;
        color: #2d3748;
        font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    .db-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .db-header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .db-header-left h1 {
        margin: 0;
        font-size: 26px;
        font-weight: 700;
        background: linear-gradient(90deg, #6366f1, #0891b2, #059669);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .db-live-dot {
        width: 8px; height: 8px;
        background: #10b981;
        border-radius: 50%;
        animation: dbPulse 2s infinite;
        display: inline-block;
    }
    .db-header-right {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 13px;
        color: rgba(0,0,0,0.5);
    }
    .db-refresh-btn {
        background: rgba(124,131,255,0.12);
        border: 1px solid rgba(124,131,255,0.25);
        color: #6366f1;
        padding: 6px 16px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 13px;
        transition: all 0.3s;
    }
    .db-refresh-btn:hover {
        background: #6366f1;
        color: #fff;
    }

    .g-card {
        background: rgba(255,255,255,0.75);
        border: 1px solid rgba(0,0,0,0.06);
        border-radius: 16px;
        backdrop-filter: blur(12px);
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        transition: transform 0.25s, box-shadow 0.25s;
    }
    .g-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    }

    .sec-title {
        font-size: 16px;
        font-weight: 600;
        color: rgba(0,0,0,0.65);
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .sec-title i {
        font-size: 14px;
        color: #6366f1;
    }

    .today-strip {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }
    .today-item {
        background: rgba(255,255,255,0.75);
        border: 1px solid rgba(0,0,0,0.06);
        border-radius: 14px;
        padding: 18px 20px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .today-item::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        border-radius: 14px 14px 0 0;
    }
    .today-item:nth-child(1)::before { background: linear-gradient(90deg, #6366f1, #a78bfa); }
    .today-item:nth-child(2)::before { background: linear-gradient(90deg, #0891b2, #0ea5e9); }
    .today-item:nth-child(3)::before { background: linear-gradient(90deg, #10b981, #059669); }
    .today-item:nth-child(4)::before { background: linear-gradient(90deg, #d97706, #f97316); }
    .today-item .ti-label {
        font-size: 12px;
        color: rgba(0,0,0,0.45);
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .today-item .ti-value {
        font-size: 28px;
        font-weight: 700;
        color: #1a202c;
    }
    .today-item .ti-sub {
        font-size: 12px;
        color: rgba(0,0,0,0.35);
        margin-top: 4px;
    }

    .kpi-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }
    .kpi-card {
        background: rgba(255,255,255,0.75);
        border: 1px solid rgba(0,0,0,0.06);
        border-radius: 14px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .kpi-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: #fff;
        flex-shrink: 0;
    }
    .kpi-icon.c1 { background: linear-gradient(135deg, #7c83ff, #6366f1); }
    .kpi-icon.c2 { background: linear-gradient(135deg, #00d4ff, #0ea5e9); }
    .kpi-icon.c3 { background: linear-gradient(135deg, #00ffab, #10b981); }
    .kpi-icon.c4 { background: linear-gradient(135deg, #f59e0b, #f97316); }
    .kpi-icon.c5 { background: linear-gradient(135deg, #ec4899, #db2777); }
    .kpi-icon.c6 { background: linear-gradient(135deg, #8b5cf6, #7c3aed); }
    .kpi-body .kpi-val {
        font-size: 24px;
        font-weight: 700;
        color: #1a202c;
    }
    .kpi-body .kpi-label {
        font-size: 12px;
        color: rgba(0,0,0,0.45);
        margin-top: 2px;
    }
    .kpi-body .kpi-sub {
        font-size: 11px;
        color: rgba(99,102,241,0.8);
        margin-top: 4px;
    }

    .personnel-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 12px;
        margin-bottom: 24px;
    }
    .p-card {
        background: rgba(255,255,255,0.7);
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 12px;
        padding: 16px;
        text-align: center;
        position: relative;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .p-card .p-icon {
        font-size: 28px;
        margin-bottom: 8px;
        display: block;
    }
    .p-card .p-count {
        font-size: 26px;
        font-weight: 700;
        color: #1a202c;
    }
    .p-card .p-name {
        font-size: 12px;
        color: rgba(0,0,0,0.45);
        margin-top: 4px;
    }
    .p-card .p-active {
        font-size: 11px;
        color: #10b981;
        margin-top: 6px;
    }
    .p-card:nth-child(1) .p-icon { color: #6366f1; }
    .p-card:nth-child(2) .p-icon { color: #0891b2; }
    .p-card:nth-child(3) .p-icon { color: #059669; }
    .p-card:nth-child(4) .p-icon { color: #d97706; }
    .p-card:nth-child(5) .p-icon { color: #db2777; }
    .p-card:nth-child(6) .p-icon { color: #7c3aed; }

    .chart-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }
    .chart-grid.tri {
        grid-template-columns: repeat(3, 1fr);
    }
    .chart-box {
        background: rgba(255,255,255,0.75);
        border: 1px solid rgba(0,0,0,0.06);
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .chart-box h3 {
        margin: 0 0 16px 0;
        font-size: 15px;
        color: rgba(0,0,0,0.65);
        font-weight: 600;
    }
    .chart-box h3 i { color: #6366f1; margin-right: 6px; font-size: 13px; }
    .chart-wrap {
        position: relative;
        height: 280px;
    }

    .pipeline {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 24px;
    }
    .pipe-step {
        background: rgba(255,255,255,0.75);
        border: 1px solid rgba(0,0,0,0.06);
        border-radius: 14px;
        padding: 18px;
        text-align: center;
        position: relative;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .pipe-step::after {
        content: '→';
        position: absolute;
        right: -12px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(0,0,0,0.2);
        font-size: 20px;
    }
    .pipe-step:last-child::after { display: none; }
    .pipe-num {
        font-size: 32px;
        font-weight: 700;
        color: #1a202c;
    }
    .pipe-label {
        font-size: 12px;
        color: rgba(0,0,0,0.45);
        margin-top: 6px;
    }
    .pipe-step:nth-child(1) .pipe-num { color: #d97706; }
    .pipe-step:nth-child(2) .pipe-num { color: #0891b2; }
    .pipe-step:nth-child(3) .pipe-num { color: #6366f1; }
    .pipe-step:nth-child(4) .pipe-num { color: #059669; }

    .eff-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }
    .eff-card {
        background: rgba(255,255,255,0.75);
        border: 1px solid rgba(0,0,0,0.06);
        border-radius: 14px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .eff-ring {
        width: 80px;
        height: 80px;
        margin: 0 auto 12px;
        position: relative;
    }
    .eff-ring canvas {
        width: 80px !important;
        height: 80px !important;
    }
    .eff-ring-val {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 16px;
        font-weight: 700;
        color: #1a202c;
    }
    .eff-label {
        font-size: 12px;
        color: rgba(0,0,0,0.5);
    }
    .eff-label.mt { margin-top: 12px; }

    .rating-display {
        text-align: center;
    }
    .rating-display .rating-value {
        font-size: 36px;
        font-weight: 700;
        color: #fbbf24;
        margin-bottom: 8px;
    }
    .rating-display .rating-stars-lg {
        font-size: 16px;
    }

    .sec-title .total-suffix {
        font-size: 12px;
        color: rgba(0,0,0,0.3);
        margin-left: auto;
    }
    .sec-title .total-suffix .hl {
        color: #6366f1;
    }

    .kpi-row.col3 {
        grid-template-columns: repeat(3, 1fr);
    }
    .kpi-icon.c7 { background: linear-gradient(135deg, #f97316, #ea580c); }
    .kpi-icon.c8 { background: linear-gradient(135deg, #ef4444, #dc2626); }

    .sys-grid.col2 {
        grid-template-columns: repeat(2, 1fr);
    }

    .table-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }
    .tbl-card {
        background: rgba(255,255,255,0.75);
        border: 1px solid rgba(0,0,0,0.06);
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .tbl-card h3 {
        margin: 0 0 14px 0;
        font-size: 15px;
        color: rgba(0,0,0,0.65);
        font-weight: 600;
    }
    .tbl-card h3 i { color: #6366f1; margin-right: 6px; font-size: 13px; }
    .dk-table {
        width: 100%;
        border-collapse: collapse;
    }
    .dk-table th {
        text-align: left;
        padding: 10px 8px;
        font-size: 11px;
        color: rgba(0,0,0,0.4);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 1px solid rgba(0,0,0,0.08);
    }
    .dk-table td {
        padding: 10px 8px;
        font-size: 13px;
        color: rgba(0,0,0,0.7);
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    .dk-table tr:hover td { background: rgba(124,131,255,0.06); }
    .rank-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 700;
    }
    .rank-badge.gold { background: linear-gradient(135deg, #fbbf24, #f59e0b); color: #fff; }
    .rank-badge.silver { background: linear-gradient(135deg, #9ca3af, #6b7280); color: #fff; }
    .rank-badge.bronze { background: linear-gradient(135deg, #d97706, #b45309); color: #fff; }
    .rank-badge.normal { background: rgba(0,0,0,0.06); color: rgba(0,0,0,0.45); }
    .rating-stars { color: #fbbf24; font-size: 11px; }

    .sys-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }
    .sys-card {
        background: rgba(255,255,255,0.75);
        border: 1px solid rgba(0,0,0,0.06);
        border-radius: 14px;
        padding: 18px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .sys-card .sys-title {
        font-size: 13px;
        color: rgba(0,0,0,0.45);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .sys-card .sys-title i { color: #6366f1; font-size: 14px; }
    .sys-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 6px 0;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    .sys-row:last-child { border: none; }
    .sys-row span:first-child {
        font-size: 12px;
        color: rgba(0,0,0,0.5);
    }
    .sys-row span:last-child {
        font-size: 14px;
        font-weight: 600;
        color: #1a202c;
    }

    .db-footer {
        text-align: center;
        padding: 16px 0 0;
        color: rgba(0,0,0,0.25);
        font-size: 12px;
    }

    .db-loading {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(238,241,248,0.95);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }
    .db-loading-ring {
        width: 48px; height: 48px;
        border: 3px solid rgba(124,131,255,0.2);
        border-top-color: #7c83ff;
        border-radius: 50%;
        animation: dbSpin 0.8s linear infinite;
    }
    .db-loading p {
        margin-top: 16px;
        color: rgba(0,0,0,0.45);
        font-size: 13px;
    }

    @@keyframes dbSpin { to { transform: rotate(360deg); } }
    @@keyframes dbPulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

    @@media (max-width: 1200px) {
        .personnel-grid { grid-template-columns: repeat(3, 1fr); }
        .chart-grid.tri { grid-template-columns: 1fr; }
    }
    @@media (max-width: 992px) {
        .today-strip, .kpi-row, .pipeline, .eff-grid { grid-template-columns: repeat(2, 1fr); }
        .chart-grid, .table-grid, .sys-grid { grid-template-columns: 1fr; }
        .personnel-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @@media (max-width: 576px) {
        .today-strip, .kpi-row, .pipeline, .eff-grid, .personnel-grid { grid-template-columns: 1fr; }
        .db-wrap { padding: 12px; }
    }
</style>

<!-- Loading -->
<div id="dbLoading" class="db-loading">
    <div class="db-loading-ring"></div>
    <p>正在加载数据看板...</p>
</div>

<div class="db-wrap">
    <!-- Header -->
    <div class="db-header">
        <div class="db-header-left">
            <h1><i class="fas fa-th-large"></i> 超级管理员数据指挥中心</h1>
            <span class="db-live-dot"></span>
        </div>
        <div class="db-header-right">
            <span id="dbLastUpdate">--</span>
            <button class="db-refresh-btn" onclick="loadDashboardData()"><i class="fas fa-sync-alt"></i> 刷新数据</button>
        </div>
    </div>

    <!-- ========== 1. Today Highlights ========== -->
    <div class="sec-title"><i class="fas fa-bolt"></i> 今日实时概览</div>
    <div class="today-strip">
        <div class="today-item">
            <div class="ti-label">今日新增订单</div>
            <div class="ti-value" id="ordersToday">-</div>
            <div class="ti-sub">已完成 <span id="completedToday">-</span> 单</div>
        </div>
        <div class="today-item">
            <div class="ti-label">今日交易金额</div>
            <div class="ti-value" id="revenueToday">-</div>
            <div class="ti-sub">今日回收 <span id="weightToday">-</span> kg</div>
        </div>
        <div class="today-item">
            <div class="ti-label">今日新增用户</div>
            <div class="ti-value" id="newUsersToday">-</div>
            <div class="ti-sub">本周活跃 <span id="activeWeek">-</span> 人</div>
        </div>
        <div class="today-item">
            <div class="ti-label">待处理事项</div>
            <div class="ti-value" id="pendingTotal">-</div>
            <div class="ti-sub">反馈 <span id="pendingFbk">-</span> | 订单 <span id="pendingOrd">-</span></div>
        </div>
    </div>

    <!-- ========== 2. Core KPI ========== -->
    <div class="sec-title"><i class="fas fa-chart-bar"></i> 核心业务指标</div>
    <div class="kpi-row">
        <div class="kpi-card">
            <div class="kpi-icon c1"><i class="fas fa-clipboard-list"></i></div>
            <div class="kpi-body">
                <div class="kpi-val" id="totalOrders">-</div>
                <div class="kpi-label">总预约订单</div>
                <div class="kpi-sub">本月 <span id="ordersMonth">-</span> | 本周 <span id="ordersWeek">-</span></div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon c2"><i class="fas fa-yen-sign"></i></div>
            <div class="kpi-body">
                <div class="kpi-val" id="totalRevenue">-</div>
                <div class="kpi-label">累计交易金额</div>
                <div class="kpi-sub">本月 ¥<span id="revenueMonth">-</span> | 本周 ¥<span id="revenueWeek">-</span></div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon c3"><i class="fas fa-weight-hanging"></i></div>
            <div class="kpi-body">
                <div class="kpi-val" id="totalWeight">-</div>
                <div class="kpi-label">累计回收重量 (kg)</div>
                <div class="kpi-sub">本月 <span id="weightMonth">-</span> kg | 本周 <span id="weightWeek">-</span> kg</div>
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-icon c4"><i class="fas fa-users"></i></div>
            <div class="kpi-body">
                <div class="kpi-val" id="totalUsers">-</div>
                <div class="kpi-label">注册用户总数</div>
                <div class="kpi-sub">本月新增 <span id="newUsersMonth">-</span></div>
            </div>
        </div>
    </div>

    <!-- ========== 3. Personnel Overview ========== -->
    <div class="sec-title"><i class="fas fa-users-cog"></i> 全平台人员总览 <span class="total-suffix">总人数: <span class="hl" id="totalPersonnel">-</span></span></div>
    <div class="personnel-grid">
        <div class="p-card">
            <span class="p-icon"><i class="fas fa-user"></i></span>
            <div class="p-count" id="pUsers">-</div>
            <div class="p-name">普通用户</div>
            <div class="p-active">本周活跃 <span id="pUsersActive">-</span></div>
        </div>
        <div class="p-card">
            <span class="p-icon"><i class="fas fa-recycle"></i></span>
            <div class="p-count" id="pRecyclers">-</div>
            <div class="p-name">回收员</div>
            <div class="p-active">可接单 <span id="pRecyclersAvail">-</span></div>
        </div>
        <div class="p-card">
            <span class="p-icon"><i class="fas fa-truck"></i></span>
            <div class="p-count" id="pTransporters">-</div>
            <div class="p-name">运输人员</div>
            <div class="p-active">空闲中 <span id="pTransportersAvail">-</span></div>
        </div>
        <div class="p-card">
            <span class="p-icon"><i class="fas fa-hard-hat"></i></span>
            <div class="p-count" id="pSortingWorkers">-</div>
            <div class="p-name">基地工作人员</div>
            <div class="p-active">在岗 <span id="pSortingActive">-</span></div>
        </div>
        <div class="p-card">
            <span class="p-icon"><i class="fas fa-user-shield"></i></span>
            <div class="p-count" id="pAdmins">-</div>
            <div class="p-name">管理员</div>
            <div class="p-active">在线 <span id="pAdminsActive">-</span></div>
        </div>
        <div class="p-card">
            <span class="p-icon"><i class="fas fa-crown"></i></span>
            <div class="p-count" id="pSuperAdmins">-</div>
            <div class="p-name">超级管理员</div>
            <div class="p-active">&nbsp;</div>
        </div>
    </div>

    <!-- ========== 4. Order Status Pipeline ========== -->
    <div class="sec-title"><i class="fas fa-project-diagram"></i> 预约订单状态管道</div>
    <div class="pipeline">
        <div class="pipe-step">
            <div class="pipe-num" id="pipePending">-</div>
            <div class="pipe-label">已预约 (待处理)</div>
        </div>
        <div class="pipe-step">
            <div class="pipe-num" id="pipeProgress">-</div>
            <div class="pipe-label">进行中</div>
        </div>
        <div class="pipe-step">
            <div class="pipe-num" id="pipeCompleted">-</div>
